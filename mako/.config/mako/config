# Global Style
font=UbuntuMono Nerd Font 12
background-color=#141414b3
text-color=#ffffff
width=350
height=150
margin=10
padding=15
border-size=1
border-color=#ffffff1a
border-radius=8
progress-color=over #ffffff33
icons=1
max-icon-size=48
default-timeout=5000
ignore-timeout=0

# Monochromatic Urgency Overrides
[urgency=low]
border-color=#ffffff1a

[urgency=normal]
border-color=#ffffff33

[urgency=critical]
border-color=#ffffff
default-timeout=0

# Match your Waybar's grouping aesthetic
[grouped]
format=<b>%g notifications</b>\n%s
