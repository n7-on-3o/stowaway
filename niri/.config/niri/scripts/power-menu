#!/usr/bin/env bash

# Define options with Nerd Font icons
# Use the Matugen-synced fuzzel.ini automatically
shutdown="  Shutdown"
reboot="󰜉  Reboot"
lock="󰌾  Lock"
suspend="󰤄  Suspend"
logout="󰍃  Logout"

# Combine options
options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"

# Launch Fuzzel with corrected -p flag
# --dmenu: tells fuzzel to act as a menu
# -p: sets the prompt text
# --lines: limits the height to the number of options
chosen="$(echo -e "$options" | fuzzel --dmenu -p "  さようなら" --lines 5 --width 20)"

# Execute based on choice
case $chosen in
    $shutdown)
        systemctl poweroff
        ;;
    $reboot)
        systemctl reboot
        ;;
    $lock)
        loginctl lock-session
        ;;
    $suspend)
        systemctl suspend
        ;;
    $logout)
        niri msg action quit
        ;;
esac
