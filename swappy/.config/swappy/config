[Default]
# Save directory (matches your wallpaper logic)
save_dir=$HOME/Pictures/Screenshots
save_filename_format=swappy-%Y%m%d-%H%M%S.png

# Line and Text settings
# Pure white (ffffff) to match your active workspace and focus ring
line_size=2
text_size=20
text_font=UbuntuMono Nerd Font

# Colors (Hex format)
# White for annotations to pop against your dark background
paint_mode=brush
early_exit=false
fill_shape=false
